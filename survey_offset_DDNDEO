<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
let rawData = [];
const S = {
  L:{p1:[],p2:[],matched:[],generated:[],screen:1,filter:'all',done:false},
  R:{p1:[],p2:[],matched:[],generated:[],screen:1,filter:'all',done:false},
};
let activeTab='L';

// ═══════════════════════════════════════════
// GLOBAL RAW UPLOAD
// ═══════════════════════════════════════════
document.getElementById('f-raw').onchange=function(e){
  const file=e.target.files[0];if(!file)return;
  readFile(file,text=>{
    rawData=parseRaw(text);
    const dz=document.getElementById('gu-dz');
    const ico=document.getElementById('gu-icon');
    const nm=document.getElementById('gu-name');
    const sub=document.getElementById('gu-sub');
    if(rawData.length===0){
      dz.className='gu-dz err';ico.textContent='⚠️';
      nm.className='gu-name err';nm.textContent=file.name;
      sub.textContent='No valid rows parsed';
    } else {
      dz.className='gu-dz ok';ico.textContent='✅';
      nm.className='gu-name ok';nm.textContent=file.name;
      sub.className='gu-sub ok';sub.textContent=rawData.length+' points loaded';
    }
    checkS1Ready('L');checkS1Ready('R');
    // hide raw warnings
    document.getElementById('L-raw-warn').classList.remove('show');
    document.getElementById('R-raw-warn').classList.remove('show');
  });
};
function guDrop(e){
  e.preventDefault();document.getElementById('gu-dz').classList.remove('over');
  const file=e.dataTransfer.files[0];if(!file)return;
  const dt=new DataTransfer();dt.items.add(file);
  document.getElementById('f-raw').files=dt.files;
  document.getElementById('f-raw').dispatchEvent(new Event('change'));
}

// ═══════════════════════════════════════════
// TAB SWITCHING
// ═══════════════════════════════════════════
function switchTab(side){
  if(side==='C'&&!S.L.done&&!S.R.done)return;
  activeTab=side;
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.getElementById('content-'+side).classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active-L','active-R','active-C'));
  if(side==='L')document.getElementById('tab-L').classList.add('active-L');
  if(side==='R')document.getElementById('tab-R').classList.add('active-R');
  if(side==='C'){document.getElementById('tab-combined').classList.add('active-C');buildCombined();}
  ['L','R','C'].forEach(s=>{const sb=document.getElementById('stepbar-'+s);if(sb)sb.style.display=s===side?'flex':'none';});
  window.scrollTo(0,0);
}

// ═══════════════════════════════════════════
// SCREEN NAV
// ═══════════════════════════════════════════
function goScreen(side,n){
  if(n===2)buildS3(side);
  S[side].screen=n;
  ['s1','s2'].forEach((s,i)=>document.getElementById(side+'-'+s).classList.toggle('active',i===n-1));
  ['sp1','sp2'].forEach((p,i)=>{
    const el=document.getElementById(side+'-'+p);
    el.classList.remove('active-L','active-R','done');
    if(i+1<n){el.classList.add('done');el.onclick=()=>goScreen(side,i+1);}
    else if(i+1===n){el.classList.add('active-'+side);el.onclick=null;}
    else{el.onclick=null;}
  });
  window.scrollTo(0,0);
}

// ═══════════════════════════════════════════
// FILE UPLOAD — PER SIDE
// ═══════════════════════════════════════════
['L','R'].forEach(side=>{
  ['p1','p2'].forEach(key=>{
    document.getElementById(side+'-f-'+key).onchange=function(e){
      const file=e.target.files[0];if(!file)return;
      readFile(file,text=>{
        const parsed=parsePoly(text);
        S[side][key]=parsed;
        setDZ(side,key,parsed.length===0?'err':'ok',file.name,parsed.length===0?'⚠ no valid rows':parsed.length+' vertices');
        checkS1Ready(side);
      });
    };
  });
});
function dzClick(side,key){document.getElementById(side+'-f-'+key).click();}
function dzOver(e,side,key){e.preventDefault();document.getElementById(side+'-dz-'+key).classList.add('over');}
function dzLeave(side,key){document.getElementById(side+'-dz-'+key).classList.remove('over');}
function dzDrop(e,side,key){
  e.preventDefault();dzLeave(side,key);
  const file=e.dataTransfer.files[0];if(!file)return;
  const dt=new DataTransfer();dt.items.add(file);
  const inp=document.getElementById(side+'-f-'+key);inp.files=dt.files;inp.dispatchEvent(new Event('change'));
}
function setDZ(side,key,status,name,sub){
  const dz=document.getElementById(side+'-dz-'+key);
  dz.className='dz '+(status==='ok'?'ok':status==='err'?'err':'');
  document.getElementById(side+'-ico-'+key).textContent=status==='ok'?'✅':'⚠️';
  const nm=document.getElementById(side+'-nm-'+key);nm.className='dz-name '+(status==='ok'?'ok':'err');nm.textContent=name;
  const sb=document.getElementById(side+'-sub-'+key);sb.className='dz-sub '+(status==='ok'?'ok':'');sb.textContent=sub;
}
function checkS1Ready(side){
  const ready=rawData.length>0&&S[side].p1.length>0&&S[side].p2.length>0;
  document.getElementById(side+'-s1-run').disabled=!ready;
  if(rawData.length===0){
    document.getElementById(side+'-raw-warn').classList.add('show');
  }
}
function readFile(file,cb){const r=new FileReader();r.onload=ev=>cb(ev.target.result);r.readAsText(file);}

// ═══════════════════════════════════════════
// PARSERS
// ═══════════════════════════════════════════
function smartSplit(line){
  const res=[];let cur='',inQ=false;
  for(let i=0;i<line.length;i++){const c=line[i];if(c==='"'){inQ=!inQ;continue;}if(c===','&&!inQ){res.push(cur.trim());cur='';}else cur+=c;}
  res.push(cur.trim());return res;
}
function parseRaw(text){
  return text.trim().split(/\r?\n/).filter(l=>l.trim()).map(line=>{
    const p=smartSplit(line);
    return{id:p[0]||'',e:parseFloat(p[1]),n:parseFloat(p[2]),z:parseFloat(p[3]),label:p[4]||''};
  }).filter(p=>!isNaN(p.e)&&!isNaN(p.n));
}
function parsePoly(text){
  const lines=text.trim().split(/\r?\n/).filter(l=>l.trim());
  const hasHdr=isNaN(parseFloat(lines[0].split(',')[0].trim()));
  return(hasHdr?lines.slice(1):lines).map(line=>{
    const p=line.split(',').map(v=>parseFloat(v.trim()));return{e:p[0],n:p[1]};
  }).filter(p=>!isNaN(p.e)&&!isNaN(p.n));
}

// ═══════════════════════════════════════════
// LABEL PARSING
// ═══════════════════════════════════════════
const PAIR_RE=/^(\d*\.?\d+)([+\-])(\d*\.?\d+)([a-zA-Z].+)?$/;
const FUSED_RE=/^([a-zA-Z][a-zA-Z0-9._]*)(\d*\.?\d+)([+\-])(\d*\.?\d+)([a-zA-Z].+)?$/;

function parseLabel(label){
  if(!label||!label.trim())return{ok:false,tokens:[],count:0,hasPairs:false,hasIncomplete:false,hasSkipped:false};
  const parts=label.trim().split('/');
  const tokens=[];let pairCount=0,hasIncomplete=false,hasSkipped=false;
  for(let i=0;i<parts.length;i++){
    const t=parts[i].trim();
    if(i===0){
      const fm=FUSED_RE.exec(t);
      if(fm){
        tokens.push({raw:t,type:'parent',desc:fm[1]});
        tokens.push({raw:t,type:'pair',offset:parseFloat(fm[2]),delta:parseFloat(fm[3]+fm[4]),desc:fm[5]||'g',note:'fused'});
        pairCount++;
      } else{tokens.push({raw:t,type:'parent',desc:t});}
      continue;
    }
    if(!t){tokens.push({raw:'',type:'skip',note:'empty'});continue;}
    const m=PAIR_RE.exec(t);
    if(m){
      tokens.push({raw:t,type:'pair',offset:parseFloat(m[1]),delta:parseFloat(m[2]+m[3]),desc:m[4]||'g'});
      pairCount++;
    } else if(/^\d*\.?\d*[+\-]$/.test(t)||/^[+\-]\d*\.?\d*$/.test(t)){
      tokens.push({raw:t,type:'incomplete',note:'missing number'});hasIncomplete=true;
    } else {
      tokens.push({raw:t,type:'skip',note:'descriptive'});hasSkipped=true;
    }
  }
  return{ok:!hasIncomplete&&pairCount>0,tokens,count:pairCount,hasPairs:pairCount>0,hasIncomplete,hasSkipped};
}

// ═══════════════════════════════════════════
// SCREEN 1 — RUN MATCH
// ═══════════════════════════════════════════
function runMatch(side){
  if(rawData.length===0){showMsg(side+'-s1-msg','err','Upload raw_points.csv first.');return;}
  const st=S[side];
  if(st.p1.length!==st.p2.length){showMsg(side+'-s1-msg','err',`Poly1 has ${st.p1.length} vertices but Poly2 has ${st.p2.length}. They must match.`);return;}
  const snap=parseFloat(document.getElementById(side+'-snap').value)||5;
  st.matched=[];
  for(let i=0;i<st.p1.length;i++){
    const pv=st.p1[i];
    let best=null,bestDist=Infinity;
    for(const pt of rawData){const d=Math.hypot(pv.e-pt.e,pv.n-pt.n);if(d<bestDist){bestDist=d;best=pt;}}
    const label=best?best.label:'';
    const parsed=parseLabel(label);
    const distFlag=bestDist>snap;
    const labelEmpty=!label||label.trim()==='';
    let status='OK';
    if(labelEmpty)status='NO LABEL';
    else if(parsed.hasIncomplete)status='INCOMPLETE';
    else if(!parsed.hasPairs)status='NO PAIRS';
    if(distFlag&&status==='OK')status='CHECK';
    st.matched.push({
      idx:i+1,pointid:best?best.id:'—',
      e:best?best.e:0,n:best?best.n:0,z:best?best.z:0,
      label,origLabel:label,dist:bestDist,distFlag,
      pairCount:parsed.count,hasSkipped:parsed.hasSkipped,
      status,skip:false,
    });
  }
  goScreen(side,2);
  updateProgress(side,'inprog');
}

// ═══════════════════════════════════════════
// SCREEN 2 — LABEL REVIEW
// ═══════════════════════════════════════════
function buildS3(side){renderS3(side,S[side].filter);updateS3Stats(side);}

function s3Filter(side,f,btn){
  S[side].filter=f;
  btn.closest('.filter-bar').querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');renderS3(side,f);
}

function renderS3(side,filter){
  const tbody=document.getElementById(side+'-s3-body');tbody.innerHTML='';let shown=0;
  S[side].matched.forEach(r=>{
    const parsed=parseLabel(r.label);
    const hasIssue=parsed.hasIncomplete||!parsed.hasPairs||r.status==='NO LABEL'||r.status==='CHECK';
    const show=filter==='all'||(filter==='issues'&&hasIssue)||(filter==='ok'&&!hasIssue&&!r.skip);
    if(!show)return;shown++;
    const realIdx=S[side].matched.indexOf(r);
    const tr=document.createElement('tr');
    if(r.skip)tr.classList.add('skipped');

    // Status badge
    let sbHtml='';
    if(r.skip){sbHtml='<span class="badge b-skip">SKIP</span>';}
    else if(parsed.hasIncomplete){sbHtml='<span class="badge b-err">INCOMPLETE</span>';}
    else if(!parsed.hasPairs||r.status==='NO LABEL'){sbHtml='<span class="badge b-none">NO PAIRS</span>';}
    else if(r.status==='CHECK'){sbHtml='<span class="badge b-warn">CHECK</span>';}
    else{sbHtml='<span class="badge b-ok">OK</span>';}
    // Skipped tokens flag
    if(parsed.hasSkipped&&!parsed.hasIncomplete&&parsed.hasPairs){
      sbHtml+=' <span class="badge b-warn" title="Some tokens were skipped as descriptive">⚠ tokens</span>';
    }

    // Show skip toggle only for problem rows
    const isProblem=parsed.hasIncomplete||!parsed.hasPairs||r.status==='NO LABEL'||r.status==='CHECK';
    const skipCell=isProblem||r.skip
      ?`<button class="skip-tog ${r.skip?'on':''}" onclick="toggleSkip3('${side}',${realIdx},this)"></button>`
      :`<span style="color:var(--text3);font-size:11px">—</span>`;

    tr.innerHTML=`
      <td class="muted">${r.idx}</td>
      <td class="mono">${r.pointid}</td>
      <td class="mono">${r.z.toFixed(3)}</td>
      <td>
        <input class="label-in ${parsed.hasIncomplete?'has-err':parsed.hasPairs?'has-ok':''}"
          id="${side}-lin-${realIdx}" value="${escHtml(r.label)}"
          oninput="onLabelInput('${side}',${realIdx},this)"/>
        <div class="parse-preview" id="${side}-pp-${realIdx}">${buildPreview(parsed)}</div>
      </td>
      <td style="text-align:center" id="${side}-pc-${realIdx}">${parsed.count}</td>
      <td id="${side}-sb-${realIdx}">${sbHtml}</td>
      <td>${skipCell}</td>
      <td><button class="reset-btn" onclick="resetLabel('${side}',${realIdx})">↺</button></td>`;
    tbody.appendChild(tr);
  });
  document.getElementById(side+'-s3-fcount').textContent=`showing ${shown} of ${S[side].matched.length}`;
}

function buildPreview(parsed){
  return parsed.tokens.map(t=>{
    if(t.type==='parent')return`<div class="pp-token"><span class="pp-parent">↳ parent: ${escHtml(t.desc)}</span></div>`;
    if(t.type==='pair')return`<div class="pp-token"><span class="pp-ok">✓</span><span style="color:var(--text2)">${escHtml(t.raw)}</span><span style="color:var(--text3);font-size:10px"> → off=${t.offset} Δ${t.delta>=0?'+':''}${t.delta} desc=${escHtml(t.desc)}</span></div>`;
    if(t.type==='incomplete')return`<div class="pp-token"><span class="pp-err">✗ ${escHtml(t.raw)} — ${t.note}</span></div>`;
    if(t.type==='skip'&&t.raw)return`<div class="pp-token"><span class="pp-skip">· ${escHtml(t.raw)} (skipped)</span></div>`;
    return'';
  }).join('');
}

function onLabelInput(side,idx,inp){
  S[side].matched[idx].label=inp.value;
  const parsed=parseLabel(inp.value);
  inp.className='label-in '+(parsed.hasIncomplete?'has-err':parsed.hasPairs?'has-ok':'');
  const pp=document.getElementById(side+'-pp-'+idx);if(pp)pp.innerHTML=buildPreview(parsed);
  const pc=document.getElementById(side+'-pc-'+idx);if(pc)pc.textContent=parsed.count;
  const sb=document.getElementById(side+'-sb-'+idx);
  if(sb){
    let html=parsed.hasIncomplete?'<span class="badge b-err">INCOMPLETE</span>':!parsed.hasPairs?'<span class="badge b-none">NO PAIRS</span>':'<span class="badge b-ok">OK</span>';
    if(parsed.hasSkipped&&!parsed.hasIncomplete&&parsed.hasPairs)html+=' <span class="badge b-warn">⚠ tokens</span>';
    sb.innerHTML=html;
  }
  updateS3Stats(side);
}

function resetLabel(side,idx){
  S[side].matched[idx].label=S[side].matched[idx].origLabel;
  const inp=document.getElementById(side+'-lin-'+idx);
  if(inp){inp.value=S[side].matched[idx].origLabel;onLabelInput(side,idx,inp);}
}

function toggleSkip3(side,idx,btn){
  S[side].matched[idx].skip=!S[side].matched[idx].skip;
  btn.classList.toggle('on');btn.closest('tr').classList.toggle('skipped');
  updateS3Stats(side);renderS3(side,S[side].filter);
}

function updateS3Stats(side){
  const m=S[side].matched;
  const active=m.filter(r=>!r.skip);
  const ok=active.filter(r=>{const p=parseLabel(r.label);return p.hasPairs&&!p.hasIncomplete;}).length;
  const inc=active.filter(r=>parseLabel(r.label).hasIncomplete).length;
  const none=active.filter(r=>{const p=parseLabel(r.label);return!p.hasPairs&&!p.hasIncomplete;}).length;
  const sk=m.filter(r=>r.skip).length;
  document.getElementById(side+'-s3-stats').innerHTML=`
    <div class="stat"><b>${m.length}</b> total</div>
    <div class="stat"><b class="ok">${ok}</b> OK</div>
    <div class="stat"><b class="err">${inc}</b> incomplete</div>
    <div class="stat"><b>${none}</b> no pairs</div>
    <div class="stat"><b class="warn">${sk}</b> skipped</div>`;
  const canGen=inc===0&&ok>0;
  document.getElementById(side+'-s3-gen').disabled=!canGen;
  const msgEl=document.getElementById(side+'-s3-msg');
  if(inc>0)showMsg(side+'-s3-msg','err',`${inc} row(s) have INCOMPLETE tokens. Fix or skip them before generating.`);
  else if(ok===0)showMsg(side+'-s3-msg','warn','No active rows with valid pairs to generate.');
  else{msgEl.className='msg';}
}

// ═══════════════════════════════════════════
// GENERATE
// ═══════════════════════════════════════════
function generatePoints(side){
  S[side].generated=[];
  let seq=1;
  S[side].matched.forEach((r,i)=>{
    if(r.skip)return;
    const parsed=parseLabel(r.label);
    if(!parsed.hasPairs||parsed.hasIncomplete)return;
    const p1=S[side].p1[i],p2=S[side].p2[i];
    if(!p1||!p2)return;
    const dx=p2.e-p1.e,dy=p2.n-p1.n,mag=Math.hypot(dx,dy);
    if(mag===0)return;
    const ux=dx/mag,uy=dy/mag;
    let curE=r.e,curN=r.n,curZ=r.z;
    parsed.tokens.forEach(t=>{
      if(t.type!=='pair')return;
      const newE=curE+t.offset*ux,newN=curN+t.offset*uy,newZ=curZ+t.delta;
      S[side].generated.push({pid:`OFF-${side}-${String(seq).padStart(3,'0')}`,e:newE,n:newN,z:newZ,desc:t.desc,parentIdx:i,parentE:r.e,parentN:r.n,parentZ:r.z});
      seq++;curE=newE;curN=newN;curZ=newZ;
    });
  });
  S[side].done=true;
  updateProgress(side,'done');
  checkOutputReady();
}

// ═══════════════════════════════════════════
// PROGRESS & OUTPUT UNLOCK
// ═══════════════════════════════════════════
function updateProgress(side,status){
  document.getElementById('pb-'+side).className='pb-status '+status;
  document.getElementById('pb-'+side).textContent={pending:'pending',inprog:'in progress',done:'✓ done'}[status];
  document.getElementById('dot-'+side).className='tab-dot '+status;
}
function checkOutputReady(){
  const anyDone=S.L.done||S.R.done;
  const bothDone=S.L.done&&S.R.done;
  const btn=document.getElementById('tab-combined');
  if(anyDone){
    btn.classList.add('ready');btn.disabled=false;
    const hint=document.getElementById('pb-hint');
    if(bothDone){hint.textContent='Both sides done — view combined output';hint.style.color='var(--ok)';}
    else{const which=S.L.done?'Left':'Right';hint.textContent=`${which} side done — view output`;hint.style.color='var(--tool-accent)';}
  }
  // Update download buttons
  document.getElementById('dl-L-btn').disabled=!S.L.done;
  document.getElementById('dl-R-btn').disabled=!S.R.done;
  document.getElementById('dl-both-btn').disabled=!bothDone;
}

// ═══════════════════════════════════════════
// COMBINED OUTPUT
// ═══════════════════════════════════════════
function buildCombined(){
  const Lg=S.L.generated,Rg=S.R.generated;
  // Left card
  document.getElementById('c-L-count').textContent=S.L.done?Lg.length+' pts':'—';
  document.getElementById('c-L-range').textContent=S.L.done&&Lg.length?`OFF-L-001 … OFF-L-${String(Lg.length).padStart(3,'0')}`:'not generated';
  // Right card
  document.getElementById('c-R-count').textContent=S.R.done?Rg.length+' pts':'—';
  document.getElementById('c-R-range').textContent=S.R.done&&Rg.length?`OFF-R-001 … OFF-R-${String(Rg.length).padStart(3,'0')}`:'not generated';
  // Download counts
  document.getElementById('dl-L-count').textContent=S.L.done?Lg.length+' pts':'—';
  document.getElementById('dl-L-range').textContent=S.L.done&&Lg.length?`OFF-L-001 … OFF-L-${String(Lg.length).padStart(3,'0')}`:'not generated';
  document.getElementById('dl-R-count').textContent=S.R.done?Rg.length+' pts':'—';
  document.getElementById('dl-R-range').textContent=S.R.done&&Rg.length?`OFF-R-001 … OFF-R-${String(Rg.length).padStart(3,'0')}`:'not generated';
  document.getElementById('dl-both-count').textContent=(Lg.length+Rg.length)+' pts';
  // Table
  const tbody=document.getElementById('c-body');tbody.innerHTML='';
  [...Lg,...Rg].forEach(g=>{
    const isL=g.pid.startsWith('OFF-L');
    const tr=document.createElement('tr');
    tr.innerHTML=`<td class="mono" style="color:${isL?'var(--left)':'var(--right)'}">${g.pid}</td><td class="mono">${g.e.toFixed(4)}</td><td class="mono">${g.n.toFixed(4)}</td><td class="mono">${g.z.toFixed(4)}</td><td style="color:var(--tool-accent)">${escHtml(g.desc)}</td>`;
    tbody.appendChild(tr);
  });
  init3D();
}

// ═══════════════════════════════════════════
// 3D — TIN TRIANGULATION
// ═══════════════════════════════════════════
let renderer3d=null;
function init3D(){
  const canvas=document.getElementById('canvas3d');
  if(renderer3d){try{renderer3d.dispose();}catch(e){}renderer3d=null;}
  const W=canvas.clientWidth||900,H=500;
  canvas.width=W;canvas.height=H;
  const scene=new THREE.Scene();
  scene.background=new THREE.Color(0x0f1419);
  const camera=new THREE.PerspectiveCamera(45,W/H,0.01,10000000);
  renderer3d=new THREE.WebGLRenderer({canvas,antialias:true});
  renderer3d.setSize(W,H);renderer3d.setPixelRatio(Math.min(window.devicePixelRatio,2));

  const allPts=[
    ...S.L.generated.map(g=>({x:g.e,y:g.z,z:g.n})),
    ...S.R.generated.map(g=>({x:g.e,y:g.z,z:g.n})),
    ...S.L.matched.filter(r=>!r.skip).map(r=>({x:r.e,y:r.z,z:r.n})),
    ...S.R.matched.filter(r=>!r.skip).map(r=>({x:r.e,y:r.z,z:r.n})),
  ];
  if(!allPts.length)return;

  const cx=allPts.reduce((a,p)=>a+p.x,0)/allPts.length;
  const cy=allPts.reduce((a,p)=>a+p.y,0)/allPts.length;
  const cz=allPts.reduce((a,p)=>a+p.z,0)/allPts.length;
  const maxSpan=Math.max(...allPts.map(p=>Math.max(Math.abs(p.x-cx),Math.abs(p.z-cz))))*2||100;

  function v3(x,y,z){return new THREE.Vector3(x-cx,y-cy,z-cz);}
  function addPoints(pts,color,size){
    if(!pts.length)return;
    const geo=new THREE.BufferGeometry();
    const pos=new Float32Array(pts.length*3);
    pts.forEach((p,i)=>{pos[i*3]=p.x-cx;pos[i*3+1]=p.y-cy;pos[i*3+2]=p.z-cz;});
    geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
    scene.add(new THREE.Points(geo,new THREE.PointsMaterial({color,size,sizeAttenuation:true})));
  }
  function addLine(pts,color,opacity=1){
    if(pts.length<2)return;
    scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts.map(p=>v3(p.x,p.y,p.z))),new THREE.LineBasicMaterial({color,transparent:opacity<1,opacity})));
  }

  // Parents
  const Lm=S.L.matched.filter(r=>!r.skip);
  const Rm=S.R.matched.filter(r=>!r.skip);
  addPoints(Lm.map(r=>({x:r.e,y:r.z,z:r.n})),0x4f8ef7,maxSpan*.014);
  addPoints(Rm.map(r=>({x:r.e,y:r.z,z:r.n})),0xf778ba,maxSpan*.014);

  // Generated
  addPoints(S.L.generated.map(g=>({x:g.e,y:g.z,z:g.n})),0x2ecc71,maxSpan*.01);
  addPoints(S.R.generated.map(g=>({x:g.e,y:g.z,z:g.n})),0xf39c12,maxSpan*.01);

  // Alignment lines
  if(Lm.length>1)addLine(Lm.map(r=>({x:r.e,y:r.z,z:r.n})),0x4f8ef7,0.4);
  if(Rm.length>1)addLine(Rm.map(r=>({x:r.e,y:r.z,z:r.n})),0xf778ba,0.4);

  // Chain lines
  function drawChains(side,color){
    const byParent={};
    S[side].generated.forEach(g=>{(byParent[g.parentIdx]=byParent[g.parentIdx]||[]).push(g);});
    Object.entries(byParent).forEach(([pidx,chain])=>{
      const parent=S[side].matched[parseInt(pidx)];if(!parent)return;
      addLine([{x:parent.e,y:parent.z,z:parent.n},...chain.map(g=>({x:g.e,y:g.z,z:g.n}))],color);
    });
  }
  drawChains('L',0x27ae60);
  drawChains('R',0xe67e22);

  // TIN surface
  function buildTIN(side,color){
    const byParent={};
    S[side].generated.forEach(g=>{(byParent[g.parentIdx]=byParent[g.parentIdx]||[]).push(g);});
    const parentIdxs=Object.keys(byParent).map(Number).sort((a,b)=>a-b);
    if(parentIdxs.length<2)return;
    const rows=[];
    parentIdxs.forEach(pidx=>{
      const parent=S[side].matched[pidx];if(!parent)return;
      rows.push([{x:parent.e,y:parent.z,z:parent.n},...byParent[pidx].map(g=>({x:g.e,y:g.z,z:g.n}))]);
    });
    if(rows.length<2)return;
    const verts=[];const idx=[];const rowOffsets=[];
    rows.forEach(row=>{rowOffsets.push(verts.length);row.forEach(p=>verts.push(p));});
    for(let r=0;r<rows.length-1;r++){
      const r0Start=rowOffsets[r],r0Len=rows[r].length;
      const r1Start=rowOffsets[r+1],r1Len=rows[r+1].length;
      let i=0,j=0;
      while(i<r0Len-1||j<r1Len-1){
        const a=r0Start+Math.min(i,r0Len-1),b=r1Start+Math.min(j,r1Len-1);
        if(i<r0Len-1&&(j>=r1Len-1||i/r0Len<=j/r1Len)){idx.push(a,b,r0Start+i+1);i++;}
        else{idx.push(a,b,r1Start+j+1);j++;}
      }
    }
    if(!idx.length)return;
    const posArr=new Float32Array(verts.length*3);
    verts.forEach((p,i)=>{posArr[i*3]=p.x-cx;posArr[i*3+1]=p.y-cy;posArr[i*3+2]=p.z-cz;});
    const geo=new THREE.BufferGeometry();
    geo.setAttribute('position',new THREE.BufferAttribute(posArr,3));
    geo.setIndex(idx);geo.computeVertexNormals();
    scene.add(new THREE.Mesh(geo,new THREE.MeshLambertMaterial({color,transparent:true,opacity:.2,side:THREE.DoubleSide,depthWrite:false})));
    scene.add(new THREE.LineSegments(new THREE.WireframeGeometry(geo),new THREE.LineBasicMaterial({color,transparent:true,opacity:.4})));
  }
  buildTIN('L',0x2ecc71);
  buildTIN('R',0xf778ba);

  scene.add(new THREE.AmbientLight(0xffffff,.8));
  const dl=new THREE.DirectionalLight(0xffffff,.4);dl.position.set(1,3,2);scene.add(dl);

  camera.position.set(maxSpan*.5,maxSpan*.25,maxSpan*.7);camera.lookAt(0,0,0);

  let isDrag=false,isRight=false,lastX=0,lastY=0;
  let theta=Math.atan2(camera.position.x,camera.position.z);
  let phi=Math.atan2(camera.position.y,Math.hypot(camera.position.x,camera.position.z));
  let radius=camera.position.length(),panX=0,panY=0;

  function updateCam(){
    camera.position.set(panX+radius*Math.sin(theta)*Math.cos(phi),panY+radius*Math.sin(phi),radius*Math.cos(theta)*Math.cos(phi));
    camera.lookAt(panX,panY,0);
  }
  canvas.addEventListener('mousedown',e=>{isDrag=true;isRight=e.button===2;lastX=e.clientX;lastY=e.clientY;e.preventDefault();});
  canvas.addEventListener('contextmenu',e=>e.preventDefault());
  window.addEventListener('mousemove',e=>{
    if(!isDrag)return;
    const dx=e.clientX-lastX,dy=e.clientY-lastY;
    if(isRight){panX-=dx*radius*.002;panY+=dy*radius*.002;}
    else{theta-=dx*.005;phi=Math.max(-.5,Math.min(Math.PI/2-.05,phi+dy*.005));}
    lastX=e.clientX;lastY=e.clientY;updateCam();
  });
  window.addEventListener('mouseup',()=>isDrag=false);
  canvas.addEventListener('wheel',e=>{radius=Math.max(maxSpan*.01,Math.min(maxSpan*6,radius+e.deltaY*radius*.001));updateCam();e.preventDefault();},{passive:false});
  let lastTD=0;
  canvas.addEventListener('touchstart',e=>{if(e.touches.length===1){isDrag=true;lastX=e.touches[0].clientX;lastY=e.touches[0].clientY;}if(e.touches.length===2)lastTD=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);e.preventDefault();},{passive:false});
  canvas.addEventListener('touchmove',e=>{
    if(e.touches.length===1&&isDrag){const dx=e.touches[0].clientX-lastX,dy=e.touches[0].clientY-lastY;theta-=dx*.005;phi=Math.max(-.5,Math.min(Math.PI/2-.05,phi+dy*.005));lastX=e.touches[0].clientX;lastY=e.touches[0].clientY;updateCam();}
    if(e.touches.length===2){const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);radius=Math.max(maxSpan*.01,Math.min(maxSpan*6,radius*(lastTD/d)));lastTD=d;updateCam();}
    e.preventDefault();
  },{passive:false});
  canvas.addEventListener('touchend',()=>isDrag=false);
  updateCam();
  function animate(){requestAnimationFrame(animate);renderer3d.render(scene,camera);}
  animate();
}

// ═══════════════════════════════════════════
// DOWNLOAD — generated points only
// ═══════════════════════════════════════════
function downloadPENZD(which){
  let rows=[];
  if(which==='L'||which==='both')rows.push(...S.L.generated.map(g=>`${g.pid},${g.e.toFixed(4)},${g.n.toFixed(4)},${g.z.toFixed(4)},${g.desc}`));
  if(which==='R'||which==='both')rows.push(...S.R.generated.map(g=>`${g.pid},${g.e.toFixed(4)},${g.n.toFixed(4)},${g.z.toFixed(4)},${g.desc}`));
  if(!rows.length)return;
  const blob=new Blob([rows.join('\n')],{type:'text/csv'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=which==='both'?'new_points_combined.csv':`new_points_OFF-${which}.csv`;
  a.click();
}

// ═══════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════
function showMsg(id,type,text){const el=document.getElementById(id);if(!el)return;el.className='msg '+type;el.textContent=text;}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
</script>
