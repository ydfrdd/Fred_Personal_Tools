<div class="progress-banner">
  <div class="pb-sides">
    <div class="pb-side"><span style="color:var(--left)">L</span><span class="pb-label">Left:</span><span class="pb-status pending" id="pb-L">pending</span></div>
    <div class="pb-side"><span style="color:var(--right)">R</span><span class="pb-label">Right:</span><span class="pb-status pending" id="pb-R">pending</span></div>
  </div>
