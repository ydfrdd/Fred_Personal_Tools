<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>C3D Offset Tool — FA Work Tools</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --tool-accent:#2ecc71;
  --tool-accent-dim:rgba(46,204,113,0.12);
  --tool-accent-border:rgba(46,204,113,0.3);
  --bg:#0f1419;
  --surface:#1a2230;
  --surface2:#1f2940;
  --border:#2a3548;
  --border2:#3a4a60;
  --text:#e8ecf0;
  --text2:#7a8fa6;
  --text3:#4a5a70;
  --ok:#2ecc71;--ok-bg:rgba(46,204,113,0.1);--ok-border:rgba(46,204,113,0.3);
  --warn:#f39c12;--warn-bg:rgba(243,156,18,0.1);--warn-border:rgba(243,156,18,0.3);
  --err:#e74c3c;--err-bg:rgba(231,76,60,0.1);--err-border:rgba(231,76,60,0.3);
  --left:#4f8ef7;--left-bg:rgba(79,142,247,0.1);--left-border:rgba(79,142,247,0.3);
  --right:#f778ba;--right-bg:rgba(247,120,186,0.1);--right-border:rgba(247,120,186,0.3);
  --mono:'Barlow Condensed',sans-serif;
  --sans:'Barlow',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;font-size:14px;line-height:1.5}

/* TOPBAR */
.topbar{background:var(--surface);border-bottom:3px solid var(--tool-accent);padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:300}
.tb-brand{display:flex;align-items:center;gap:14px;text-decoration:none}
.tb-logo{font-family:var(--mono);font-size:16px;font-weight:800;letter-spacing:2px;color:var(--tool-accent)}
.tb-sep{width:1px;height:24px;background:var(--border2)}
.tb-tool{font-family:var(--mono);font-size:14px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text)}
.tb-sub{font-size:12px;color:var(--text2);margin-top:1px}
.tb-right{display:flex;align-items:center;gap:10px}
.tb-back{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:5px 14px;border-radius:4px;border:1px solid var(--border2);background:transparent;color:var(--text2);text-decoration:none;transition:all .15s}
.tb-back:hover{border-color:var(--tool-accent);color:var(--tool-accent)}

/* GLOBAL UPLOAD */
.global-upload{background:var(--surface);border-bottom:1px solid var(--border);padding:1rem 2rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap}
.gu-label{font-family:var(--mono);font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);white-space:nowrap}
.gu-dz{display:flex;align-items:center;gap:10px;padding:8px 16px;background:var(--surface2);border:1px dashed var(--border2);border-radius:6px;cursor:pointer;transition:all .2s;min-width:260px}
.gu-dz:hover,.gu-dz.over{border-color:var(--tool-accent);background:var(--tool-accent-dim)}
.gu-dz.ok{border-style:solid;border-color:var(--ok);background:var(--ok-bg)}
.gu-dz.err{border-style:solid;border-color:var(--err);background:var(--err-bg)}
.gu-icon{font-size:18px;flex-shrink:0}
.gu-text{display:flex;flex-direction:column;gap:1px}
.gu-name{font-family:var(--mono);font-size:12px;font-weight:600;color:var(--text2)}
.gu-name.ok{color:var(--ok)}.gu-name.err{color:var(--err)}
.gu-sub{font-size:11px;color:var(--text3)}
.gu-sub.ok{color:var(--ok);opacity:.8}
input[type=file]{display:none}

/* TABBAR */
.tabbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:stretch;position:sticky;top:56px;z-index:200}
.tab-btn{display:flex;align-items:center;gap:8px;padding:.75rem 1.5rem;font-family:var(--mono);font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:none;background:transparent;color:var(--text3);border-bottom:3px solid transparent;transition:all .15s;white-space:nowrap;margin-bottom:-1px}
.tab-btn:hover{color:var(--text2)}
.tab-btn.active-L{color:var(--left);border-bottom-color:var(--left)}
.tab-btn.active-R{color:var(--right);border-bottom-color:var(--right)}
.tab-btn.active-C{color:var(--tool-accent);border-bottom-color:var(--tool-accent)}
.tab-dot{width:7px;height:7px;border-radius:50%;transition:background .2s;flex-shrink:0}
.tab-dot.pending{background:var(--border2)}
.tab-dot.inprog{background:var(--warn)}
.tab-dot.done{background:var(--ok)}
.tab-sep{width:1px;background:var(--border);margin:.5rem 0}
.tab-combined{margin-left:auto;display:flex;align-items:center;gap:8px;padding:.75rem 1.5rem;font-family:var(--mono);font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:none;background:transparent;color:var(--text3);border-bottom:3px solid transparent;transition:all .15s;margin-bottom:-1px}
.tab-combined.ready{color:var(--tool-accent);border-bottom-color:var(--tool-accent)}
.tab-combined:not(.ready){cursor:not-allowed;opacity:.3}

/* STEPBAR */
.stepbar{background:var(--bg);border-bottom:1px solid var(--border);padding:.6rem 2rem;display:flex;align-items:center;overflow-x:auto}
.step-pill{display:flex;align-items:center;gap:7px;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:4px 14px;border-radius:20px;border:1px solid var(--border);color:var(--text3);white-space:nowrap;transition:all .2s;cursor:default}
.step-pill.active-L{border-color:var(--left);color:var(--left);background:var(--left-bg)}
.step-pill.active-R{border-color:var(--right);color:var(--right);background:var(--right-bg)}
.step-pill.done{border-color:var(--ok);color:var(--ok);background:var(--ok-bg);cursor:pointer}
.step-conn{width:28px;height:1px;background:var(--border);flex-shrink:0;margin:0 4px}

/* LAYOUT */
.container{max-width:1040px;margin:0 auto;padding:2rem 2rem 5rem}
.tab-content{display:none}.tab-content.active{display:block}
.screen{display:none}.screen.active{display:block}

/* PAGE HEADER */
.ph{margin-bottom:1.5rem}
.ph h1{font-family:var(--mono);font-size:28px;font-weight:800;color:var(--text);letter-spacing:-0.5px;margin-bottom:6px;line-height:1.1}
.ph p{font-size:14px;color:var(--text2);line-height:1.65}
.side-tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;font-weight:700;padding:3px 10px;border-radius:3px;margin-bottom:10px;letter-spacing:2px;text-transform:uppercase}
.side-tag-L{background:var(--left-bg);color:var(--left);border:1px solid var(--left-border)}
.side-tag-R{background:var(--right-bg);color:var(--right);border:1px solid var(--right-border)}

/* UPLOAD GRID */
.upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.dz{background:var(--surface);border:1px dashed var(--border2);border-radius:8px;padding:1.25rem;cursor:pointer;transition:all .2s;min-height:100px;display:flex;flex-direction:column;gap:6px}
.dz:hover,.dz.over{border-color:var(--tool-accent);background:var(--tool-accent-dim)}
.dz.ok{border-style:solid;border-color:var(--ok);background:var(--ok-bg)}
.dz.err{border-style:solid;border-color:var(--err);background:var(--err-bg)}
.dz-tag{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3)}
.dz-icon{font-size:22px;line-height:1}
.dz-name{font-family:var(--mono);font-size:13px;color:var(--text2)}
.dz-name.ok{color:var(--ok);font-weight:600}.dz-name.err{color:var(--err);font-weight:600}
.dz-sub{font-size:12px;color:var(--text3)}
.dz-sub.ok{color:var(--ok);opacity:.8}

/* SETTINGS */
.srow{display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:1rem 1.25rem;margin-bottom:14px}
.slabel{font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text2);white-space:nowrap}
.snap-in{width:80px;padding:6px 10px;background:var(--surface2);border:1px solid var(--border2);border-radius:5px;color:var(--text);font-family:var(--mono);font-size:13px}
.snap-in:focus{outline:none;border-color:var(--tool-accent)}

/* MESSAGES */
.msg{font-family:var(--mono);font-size:12px;font-weight:600;padding:9px 14px;border-radius:6px;margin-bottom:14px;display:none;letter-spacing:.5px}
.msg.err{background:var(--err-bg);color:var(--err);border:1px solid var(--err-border);display:block}
.msg.ok{background:var(--ok-bg);color:var(--ok);border:1px solid var(--ok-border);display:block}
.msg.warn{background:var(--warn-bg);color:var(--warn);border:1px solid var(--warn-border);display:block}

/* BUTTONS */
.btn{padding:8px 20px;font-family:var(--mono);font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;border-radius:5px;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);transition:all .15s}
.btn:hover:not(:disabled){border-color:var(--tool-accent);color:var(--tool-accent)}
.btn:disabled{opacity:.3;cursor:not-allowed}
.btn-accent{border-color:var(--tool-accent);background:var(--tool-accent-dim);color:var(--tool-accent)}
.btn-accent:hover:not(:disabled){background:var(--tool-accent);color:#0f1419}
.btn-L{border-color:var(--left);background:var(--left-bg);color:var(--left)}
.btn-L:hover:not(:disabled){background:var(--left);color:#fff}
.btn-R{border-color:var(--right);background:var(--right-bg);color:var(--right)}
.btn-R:hover:not(:disabled){background:var(--right);color:#fff}
.btn-ok{border-color:var(--ok);background:var(--ok-bg);color:var(--ok)}
.btn-ok:hover:not(:disabled){background:var(--ok);color:#0f1419}
.btn-full{width:100%;margin-top:10px;padding:11px}
.btn-sm{padding:4px 10px;font-size:11px}

/* FILTER BAR */
.filter-bar{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;align-items:center}
.filter-btn{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:4px 12px;border-radius:12px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;transition:all .15s}
.filter-btn.active{border-color:var(--tool-accent);color:var(--tool-accent);background:var(--tool-accent-dim)}
.filter-count{font-family:var(--mono);font-size:11px;color:var(--text3);margin-left:auto}

/* STATS */
.stats-row{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:14px}
.stat{font-family:var(--mono);font-size:12px;color:var(--text3)}
.stat b{color:var(--text);font-weight:700}
.stat b.ok{color:var(--ok)}.stat b.warn{color:var(--warn)}.stat b.err{color:var(--err)}

/* TABLE */
.tbl-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:8px;margin-bottom:14px}
.out-tbl-wrap{max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;margin-bottom:1.5rem}
table{width:100%;border-collapse:collapse;font-size:13px}
thead tr{background:var(--surface2)}
th{text-align:left;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);padding:9px 12px;border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:8px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--surface2)}
tr.skipped td{opacity:.3}
td.muted{color:var(--text3);font-family:var(--mono);font-size:12px}
td.warn-c{color:var(--warn)}
td.mono{font-family:var(--mono);font-size:12px}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:4px;font-family:var(--mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;letter-spacing:1px;text-transform:uppercase;white-space:nowrap}
.b-ok{background:var(--ok-bg);color:var(--ok);border:1px solid var(--ok-border)}
.b-warn{background:var(--warn-bg);color:var(--warn);border:1px solid var(--warn-border)}
.b-err{background:var(--err-bg);color:var(--err);border:1px solid var(--err-border)}
.b-none{background:var(--surface2);color:var(--text3);border:1px solid var(--border)}
.b-skip{background:var(--surface);color:var(--text3);border:1px solid var(--border)}

/* LABEL EDITOR */
.label-in{width:100%;min-width:200px;padding:5px 9px;background:var(--surface2);border:1px solid var(--border2);border-radius:5px;color:var(--text);font-family:var(--mono);font-size:12px;transition:border-color .15s}
.label-in:focus{outline:none;border-color:var(--tool-accent)}
.label-in.has-err{border-color:var(--err)}.label-in.has-ok{border-color:var(--ok)}
.parse-preview{margin-top:5px;font-family:var(--mono);font-size:11px;line-height:1.9}
.pp-ok{color:var(--ok)}.pp-err{color:var(--err)}.pp-skip{color:var(--text3)}.pp-parent{color:var(--tool-accent)}
.pp-token{display:flex;gap:6px;align-items:baseline}

/* SKIP TOGGLE */
.skip-tog{width:36px;height:20px;border-radius:10px;border:1px solid var(--border2);background:var(--surface2);cursor:pointer;position:relative;transition:background .2s,border-color .2s;flex-shrink:0}
.skip-tog.on{background:var(--warn-bg);border-color:var(--warn)}
.skip-tog::after{content:'';position:absolute;top:3px;left:3px;width:12px;height:12px;border-radius:50%;background:var(--text3);transition:transform .2s,background .2s}
.skip-tog.on::after{transform:translateX(16px);background:var(--warn)}
.reset-btn{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:1px;padding:3px 9px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;transition:all .15s}
.reset-btn:hover{border-color:var(--warn);color:var(--warn)}

/* BOTTOM BAR */
.bottom-bar{display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid var(--border);margin-top:16px;gap:10px;flex-wrap:wrap}

/* PROGRESS BANNER */
.progress-banner{position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);padding:.65rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:12px;z-index:400;flex-wrap:wrap}
.pb-sides{display:flex;gap:24px}
.pb-side{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase}
.pb-label{color:var(--text3)}
.pb-status{font-weight:700}
.pb-status.pending{color:var(--text3)}.pb-status.inprog{color:var(--warn)}.pb-status.done{color:var(--ok)}
.pb-hint{font-family:var(--mono);font-size:11px;color:var(--text3);font-weight:600;letter-spacing:1px}

/* 3D VIZ */
.viz-wrap{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:1.5rem}
.viz-header{display:flex;justify-content:space-between;align-items:center;padding:10px 16px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:10px}
.viz-title{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2)}
.viz-legend{display:flex;gap:14px;flex-wrap:wrap}
.leg-item{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:11px;color:var(--text2)}
.leg-dot{width:8px;height:8px;border-radius:50%}
#canvas3d{width:100%;height:500px;display:block;cursor:grab}
#canvas3d:active{cursor:grabbing}
.viz-hint{font-family:var(--mono);font-size:10px;color:var(--text3);padding:5px 16px;border-top:1px solid var(--border);text-align:center;letter-spacing:1px}

/* COMBINED CARDS */
.combined-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1.5rem}
.combined-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px}
.combined-card-title{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
.combined-card-title.L{color:var(--left)}.combined-card-title.R{color:var(--right)}
.combined-stat{font-family:var(--mono);font-size:28px;font-weight:800;color:var(--text);margin-bottom:3px;letter-spacing:-1px}
.combined-sub{font-family:var(--mono);font-size:11px;color:var(--text3)}

/* DOWNLOAD SECTION */
.dl-section{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1.5rem}
.dl-title{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:14px}
.dl-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.dl-card{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:14px 16px;display:flex;flex-direction:column;gap:8px}
.dl-card-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase}
.dl-card-label.L{color:var(--left)}.dl-card-label.R{color:var(--right)}.dl-card-label.both{color:var(--tool-accent)}
.dl-card-count{font-family:var(--mono);font-size:20px;font-weight:800;color:var(--text)}
.dl-card-desc{font-family:var(--mono);font-size:11px;color:var(--text3)}

/* RAW UPLOAD REQUIRED */
.raw-required{background:var(--warn-bg);border:1px solid var(--warn-border);border-radius:8px;padding:12px 16px;font-family:var(--mono);font-size:12px;color:var(--warn);font-weight:600;letter-spacing:.5px;margin-bottom:14px;display:none}
.raw-required.show{display:block}

@media(max-width:700px){
  .upload-grid,.combined-grid,.dl-grid{grid-template-columns:1fr}
  .topbar,.tabbar,.global-upload{padding:0 1rem}
  .container{padding:1.5rem 1rem 5rem}
  .global-upload{padding:.75rem 1rem}
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <a class="tb-brand" href="../index.html">
    <div class="tb-logo">FA</div>
    <div class="tb-sep"></div>
    <div>
      <div class="tb-tool">C3D Offset Tool</div>
      <div class="tb-sub">Survey Point Generator</div>
    </div>
  </a>
  <div class="tb-right">
    <a class="tb-back" href="../index.html">← Back to Tools</a>
  </div>
</div>

<!-- GLOBAL RAW UPLOAD -->
<div class="global-upload">
  <div class="gu-label">Raw Points</div>
  <div class="gu-dz" id="gu-dz" onclick="document.getElementById('f-raw').click()"
       ondragover="event.preventDefault();this.classList.add('over')"
       ondragleave="this.classList.remove('over')"
       ondrop="guDrop(event)">
    <div class="gu-icon" id="gu-icon">📂</div>
    <div class="gu-text">
      <div class="gu-name" id="gu-name">raw_points.csv</div>
      <div class="gu-sub" id="gu-sub">Shared by both sides — upload once</div>
    </div>
  </div>
  <input type="file" id="f-raw" accept=".csv,.txt">
  <div style="font-family:var(--mono);font-size:11px;color:var(--text3);letter-spacing:.5px">PointID · Easting · Northing · Elevation · Label</div>
</div>

<!-- TABBAR -->
<div class="tabbar">
  <button class="tab-btn active-L" id="tab-L" onclick="switchTab('L')">
    <div class="tab-dot pending" id="dot-L"></div> Left Side
  </button>
  <div class="tab-sep"></div>
  <button class="tab-btn" id="tab-R" onclick="switchTab('R')">
    <div class="tab-dot pending" id="dot-R"></div> Right Side
  </button>
  <button class="tab-combined" id="tab-combined" onclick="switchTab('C')" disabled>
    ⊕ Output & Visualization
  </button>
</div>

<!-- STEPBARS -->
<div id="stepbar-L" class="stepbar">
  <div class="step-pill active-L" id="L-sp1">① Upload & Match</div>
  <div class="step-conn"></div>
  <div class="step-pill" id="L-sp2">② Label Review</div>
</div>
<div id="stepbar-R" class="stepbar" style="display:none">
  <div class="step-pill active-R" id="R-sp1">① Upload & Match</div>
  <div class="step-conn"></div>
  <div class="step-pill" id="R-sp2">② Label Review</div>
</div>
<div id="stepbar-C" style="display:none"></div>

<!-- LEFT SIDE -->
<div class="tab-content active" id="content-L">
  <!-- S1 -->
  <div class="screen active" id="L-s1"><div class="container">
    <div class="ph"><div class="side-tag side-tag-L">◀ Left Side</div><h1>Upload & Match</h1><p>Upload the original and offset polylines for the left side. The tool matches each vertex to the nearest raw point.</p></div>
    <div class="raw-required" id="L-raw-warn">⚠ Upload raw_points.csv above before running the matcher.</div>
    <div class="upload-grid">
